{
  "buildCommand": "npm run build -- --configuration production",
  "outputDirectory": "dist/frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://monitors-graduate-sink-receive.trycloudflare.com/api/:path*"
    },
    {
      "source": "/ml/:path*",
      "destination": "https://instead-broker-provide-forecast.trycloudflare.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
